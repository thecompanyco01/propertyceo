{
  "rewrites": [
    { "source": "/buy", "destination": "/buy.html" },
    { "source": "/thank-you", "destination": "/thank-you.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/products", "destination": "/products/index.html" },
    { "source": "/products/:slug", "destination": "/products/:slug.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/cities/:slug", "destination": "/cities/:slug.html" },
    { "source": "/services/:slug", "destination": "/services/:slug.html" },
    { "source": "/states/:slug", "destination": "/states/:slug.html" },
    { "source": "/compare/:slug", "destination": "/compare/:slug.html" },
    { "source": "/eviction/:slug", "destination": "/eviction/:slug.html" },
    { "source": "/api/waitlist", "destination": "/api/waitlist.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/blog/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/cities/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
