{
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/cities/:slug", "destination": "/cities/:slug.html" },
    { "source": "/services/:slug", "destination": "/services/:slug.html" },
    { "source": "/states/:slug", "destination": "/states/:slug.html" },
    { "source": "/compare/:slug", "destination": "/compare/:slug.html" },
    { "source": "/api/waitlist", "destination": "/api/waitlist.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
